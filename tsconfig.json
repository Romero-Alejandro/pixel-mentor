{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@pixel-mentor/api/*": ["./apps/api/src/*"],
      "@pixel-mentor/web/*": ["./apps/web/src/*"],
      "@pixel-mentor/shared/*": ["./packages/shared/src/*"]
    }
  },

  "include": ["apps/*/src/**/*", "packages/*/src/**/*", "**/*.ts", "**/*.tsx"],
  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/build",
    "**/.turbo",
    "**/postcss.config.js",
    "**/tailwind.config.js"
  ]
}
