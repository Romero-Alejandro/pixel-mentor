{
  "name": "@pixel-mentor/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/entry.ts",
    "prebuild": "rimraf dist",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "lint": "eslint . --fix",
    "format": "prettier . --write --ignore-unknown",
    "test": "jest",
    "setup": "cp .env.example .env && echo 'Created .env from .env.example. Edit with your values.'",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed-test-data.ts",
    "db:seed:admin": "tsx prisma/seed-admin.ts",
    "db:seed:gamification": "tsx prisma/seed-gamification.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google-cloud/text-to-speech": "^6.4.0",
    "@google/generative-ai": "0.24.1",
    "@huggingface/inference": "^4.13.15",
    "@prisma/client": "6.19.2",
    "@sefinek/google-tts-api": "^2.1.13",
    "argon2": "0.44.0",
    "cors": "2.8.6",
    "dotenv": "17.3.1",
    "edge-tts-universal": "^1.4.0",
    "express": "5.2.1",
    "express-rate-limit": "8.3.0",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.3",
    "msedge-tts": "^2.0.4",
    "openai": "^4.86.0",
    "pino": "10.3.1",
    "pino-http": "^10.4.0",
    "supertest": "7.2.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@babel/preset-typescript": "7.28.5",
    "@prisma/config": "6.19.2",
    "@swc/core": "1.15.18",
    "@swc/jest": "0.2.39",
    "@types/bcrypt": "5.0.2",
    "@types/cors": "2.8.19",
    "@types/dotenv": "8.2.3",
    "@types/express": "5.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.3.5",
    "eslint": "10.0.3",
    "jest": "30.2.0",
    "pino-pretty": "13.1.3",
    "prisma": "6.19.2",
    "rimraf": "6.1.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
