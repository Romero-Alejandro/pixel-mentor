    "@tabler/icons-react": "3.40.0",
    "@tanstack/react-query": "5.90.21",
    "axios": "1.13.6",
    "clsx": "2.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "7.13.1",
    "rive-react": "4.24.0",
    "tailwind-merge": "3.5.0",
    "use-sound": "5.0.0",
