{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    /* Seteamos rootDir al nivel de la API para incluir los .config.ts sin errores */
    "rootDir": ".",
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
    },
    /* Eliminamos typeRoots por completo para que TS use su lógica estándar de búsqueda */
  },
  "include": ["src/**/*", "tsup.config.ts", "prisma.config.ts"],
  "exclude": ["node_modules", "dist"],
}
