{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",

    "rootDir": ".",
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": ["./src/*"],
      "@/features/*": ["./src/features/*"],
      "@/shared/*": ["./src/shared/*"],
      "@/main/*": ["./src/main/*"],
      "@/infra/*": ["./src/infrastructure/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "tsup.config.ts", "prisma.config.ts"],
  "exclude": ["src/**/__tests__", "src/**/generated/**", "node_modules", "dist"]
}
