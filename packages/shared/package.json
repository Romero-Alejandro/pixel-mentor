{
  "name": "@pixel-mentor/shared",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./auth": "./src/auth.ts",
    "./recipe": "./src/recipe.ts",
    "./session": "./src/session.ts",
    "./pedagogical": "./src/pedagogical.ts",
    "./types/tts": "./src/types/tts.ts",
    "./gamification": "./src/gamification/index.ts",
    "./schemas": "./src/schemas/index.ts",
    "./schemas/class": "./src/schemas/class.schema.ts",
    "./schemas/recipe": "./src/schemas/recipe/index.ts",
    "./schemas/recipe/step-content": "./src/schemas/recipe/step-content.schema.ts",
    "./schemas/recipe/activity-option": "./src/schemas/recipe/activity-option.schema.ts",
    "./schemas/recipe/activity-content": "./src/schemas/recipe/activity-content.schema.ts",
    "./schemas/recipe/static-content": "./src/schemas/recipe/static-content.schema.ts",
    "./schemas/recipe/step-script": "./src/schemas/recipe/step-script.schema.ts",
    "./schemas/recipe/question": "./src/schemas/recipe/question.schema.ts",
    "./schemas/recipe/recipe": "./src/schemas/recipe/recipe.schema.ts",
    "./schemas/orchestration": "./src/schemas/orchestration/index.ts",
    "./schemas/orchestration/start-recipe": "./src/schemas/orchestration/start-recipe.schema.ts",
    "./schemas/orchestration/interact": "./src/schemas/orchestration/interact.schema.ts",
    "./schemas/orchestration/interaction-chunk": "./src/schemas/orchestration/interaction-chunk.schema.ts",
    "./schemas/evaluation": "./src/schemas/evaluation/index.ts",
    "./schemas/evaluation/question": "./src/schemas/evaluation/question.schema.ts",
    "./schemas/session": "./src/schemas/session/index.ts",
    "./schemas/session/session": "./src/schemas/session/session.schema.ts",
    "./schemas/validation": "./src/schemas/validation.schema.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier . --write --ignore-unknown",
    "test": "jest"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    }
  }
}
