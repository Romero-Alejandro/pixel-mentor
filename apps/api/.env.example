# Pixel Mentor API - Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit this file to version control

# ===========================================
# Server Configuration
# ===========================================
PORT=3001
NODE_ENV=development # 'development' | 'production' | 'test' | 'staging'
CORS_ORIGIN=http://localhost:5173

# ===========================================
# Database (Supabase/Postgres)
# ===========================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL=postgresql://admin_user:SecurePassword_123%21@localhost:5432/pixel_mentor_db_dev?schema=public

# ===========================================
# LLM Provider Configuration
# ===========================================
# Primary provider: 'gemini' | 'openrouter' | 'groq'
LLM_PROVIDER=groq

# API Keys (at least the one for your selected provider is required)
GEMINI_API_KEY=your-gemini-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# Default Models per Provider
DEFAULT_MODEL_GEMINI=gemini-2.5-flash-lite
DEFAULT_MODEL_OPENROUTER=stepfun/step-3.5-flash:free
DEFAULT_MODEL_GROQ=llama-3.3-70b-versatile

# OpenRouter Metadata (optional, used for provider analytics)
OPENROUTER_APP_URL=http://localhost:3001
OPENROUTER_APP_NAME=Pixel Mentor

# ===========================================
# JWT Authentication (REQUIRED)
# ===========================================
# JWT_SECRET: Must be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# JWT_REFRESH_SECRET: Optional, if not set uses JWT_SECRET
# Recommended to use a separate secret for refresh tokens
# JWT_REFRESH_SECRET=

# Token expiration times
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# Admin User (seed-admin script)
# ===========================================
# Set these before running: pnpm db:seed:admin
ADMIN_EMAIL=admin@pixel-mentor.local
ADMIN_PASSWORD=Admin2026!
ADMIN_NAME=Administrador
ADMIN_USERNAME=admin

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info # 'trace' | 'debug' | 'info' | 'warn' | 'error' | 'fatal'

# ===========================================
# Rate Limiting (per window)
# ===========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10
RATE_LIMIT_MAX_INTERACT=5

# ===========================================
# Request Timeout (milliseconds)
# ===========================================
REQUEST_TIMEOUT_MS=30000

# ===========================================
# Feature Flags
# ===========================================
ENABLE_STREAMING=true
USE_NEW_EVALUATOR_ENGINE=false

# ===========================================
# Text-to-Speech (TTS) Configuration
# ===========================================
# Provider: google-free (default, free) | mock (for testing)
TTS_PROVIDER=google-free

# ===========================================
# LLM Governance - Cost Protection & Security
# ===========================================
# Maximum prompt length in characters
LLM_MAX_PROMPT_LENGTH=16000
# Maximum user input length in characters
LLM_MAX_USER_INPUT_LENGTH=2000
# Default LLM interactions quota per user per day
LLM_DEFAULT_USER_QUOTA=100
# Global daily budget in USD (prevents runaway costs)
LLM_DAILY_BUDGET_USD=10
# Maximum LLM requests per user per hour
LLM_MAX_REQUESTS_PER_USER_PER_HOUR=60
